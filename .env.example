# ==========================================
# TRD-LEX Environment Variables — EXAMPLE
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------
# Database Settings (PostgreSQL)
# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trd_lex
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trd_lex?schema=public"

# ----------------------------
# pgAdmin Settings
# ----------------------------
PGADMIN_DEFAULT_EMAIL=admin@trd.go.th
PGADMIN_DEFAULT_PASSWORD=admin1234

# ----------------------------
# Authentication & Security
# ----------------------------
# ⚠️  CHANGE THIS IN PRODUCTION! Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------
# Application Settings
# ----------------------------
PORT=8000
NODE_ENV=development
API_VERSION=v1

# ----------------------------
# Frontend (Next.js)
# ----------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------
# Mock ThaID Settings
# ----------------------------
THAID_CLIENT_ID=mock_thaid_client_id
THAID_CLIENT_SECRET=mock_thaid_client_secret

# ----------------------------
# Google Cloud (optional — for deployment)
# ----------------------------
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=asia-southeast1
# GCR_HOSTNAME=asia.gcr.io
