# ==========================================
# TRD Lease Exchange (TRD-LEX) — .gitignore
# ==========================================

# ----------------------------
# Environment variables (CRITICAL — never commit secrets)
# ----------------------------
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ----------------------------
# Node.js / Frontend
# ----------------------------
node_modules/
jspm_packages/
web_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ----------------------------
# Next.js
# ----------------------------
.next/
out/
build/
.vercel

# ----------------------------
# Python / Backend
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.venv/
venv/
ENV/
env/
*.egg-info/
dist/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------
# Prisma
# ----------------------------
# Generated Prisma Client (will be regenerated on build)
backend/app/prisma/

# ----------------------------
# Docker
# ----------------------------
# Don't ignore docker-compose.yml (it's needed)
# But ignore temporary docker volumes
postgres_data/
pgadmin_data/

# ----------------------------
# IDEs and Editors
# ----------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# ----------------------------
# OS Files
# ----------------------------
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db
Icon?

# ----------------------------
# Logs
# ----------------------------
*.log
logs/

# ----------------------------
# Testing
# ----------------------------
coverage/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ----------------------------
# Misc
# ----------------------------
*.bak
*.tmp
*.temp
.snapshots/
